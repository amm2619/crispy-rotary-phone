rules_version = '2';

// Security rules for Records — each signed-in user can only read/write
// documents under their own users/{uid}/... subtree. No cross-user access.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
